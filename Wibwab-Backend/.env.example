# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามเครื่องตัวเอง (ห้าม commit .env จริง)

# Backend
PORT=8080
JWT_SECRET=change-this-secret
FRONTEND_URL=http://localhost:5173

# Database (ตรงกับ docker-compose.yml)
DB_HOST=localhost
DB_PORT=3306
DB_USER=wibwab
DB_PASSWORD=wibwab_pass
DB_NAME=wibwab_db

# SMTP — ใช้ส่งอีเมล OTP รีเซ็ตรหัสผ่านฝั่ง Admin (ของจริง ไม่จำลอง)
# ถ้าใช้ Gmail: ต้องเปิด 2-Step Verification ในบัญชีที่จะใช้ "ส่ง" ก่อน แล้วสร้าง App Password
# ที่ https://myaccount.google.com/apppasswords (ห้ามใช้รหัสผ่าน Gmail จริงตรงๆ ใช้ไม่ได้)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="วิบวับ <your-sending-email@gmail.com>"
